<% const pageTitle=article ? 'Edit Artikel' : 'Tulis Artikel Baru' ; %>

    <!-- Include EasyMDE -->
    <link rel="stylesheet" href="https://unpkg.com/easymde/dist/easymde.min.css">
    <script src="https://unpkg.com/easymde/dist/easymde.min.js"></script>

    <style>
        .Editor-container .CodeMirror {
            border-radius: 0 0 15px 15px;
            border-color: #cbd5e1;
            font-family: 'Fira Code', monospace;
            font-size: 14px;
            background: #ffffff;
        }

        .Editor-container .editor-toolbar {
            border-radius: 15px 15px 0 0;
            border-color: #cbd5e1;
            background: #f8fafc;
        }

        .editor-preview-side pre,
        .editor-preview pre {
            background: #1e293b;
            color: #f8fafc;
            padding: 1.5rem;
            border-radius: 12px;
            font-size: 13px;
        }

        .upload-indicator {
            display: none;
            position: fixed;
            bottom: 30px;
            right: 30px;
            z-index: 999;
            background: #10b981;
            color: white;
            padding: 10px 20px;
            border-radius: 50px;
            font-weight: bold;
            box-shadow: 0 10px 20px rgba(16, 185, 129, 0.3);
        }
    </style>

    <div id="uploadStatus" class="upload-indicator">
        <i class="fas fa-spinner fa-spin mr-2"></i> Sedang mengunggah gambar...
    </div>

    <!-- Hidden File Input for Manual Trigger -->
    <input type="file" id="manualUpload" style="display:none" accept="image/*" onchange="manualUploadChange(this)">

    <div class="row">
        <div class="col-lg-12">
            <form id="articleForm" action="/admin/articles/save" method="POST" enctype="multipart/form-data">
                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div>
                        <a href="/admin/articles" class="text-muted small font-weight-bold">
                            <i class="fas fa-arrow-left mr-1"></i> Kembali
                        </a>
                        <h1 class="h3 font-weight-bold mt-2">
                            <%= pageTitle %>
                        </h1>
                    </div>
                    <button type="submit" class="btn btn-primary px-5 shadow-sm">
                        <i class="fas fa-save mr-2"></i> Simpan Artikel
                    </button>
                </div>

                <% if(article) { %>
                    <input type="hidden" name="id" value="<%= article.id %>">
                    <input type="hidden" name="existingCoverImage" value="<%= article.coverImage %>">
                    <% } %>

                        <div class="row">
                            <div class="col-md-9">
                                <div class="card mb-4 shadow-none border">
                                    <div class="card-body">
                                        <div class="form-group mb-4">
                                            <label class="text-xs font-weight-bold text-uppercase text-muted">Judul
                                                Artikel</label>
                                            <input type="text" name="title"
                                                class="form-control form-control-lg border-0 bg-light font-weight-bold"
                                                style="font-size: 1.5rem;" value="<%= article ? article.title : '' %>"
                                                required placeholder="Judul yang Menarik...">
                                        </div>

                                        <div class="form-group mb-4">
                                            <label class="text-xs font-weight-bold text-uppercase text-muted">Ringkasan
                                                Singkat</label>
                                            <textarea name="excerpt" class="form-control bg-light border-0" rows="2"
                                                placeholder="Tuliskan intisari artikel..."><%= article ? article.excerpt : '' %></textarea>
                                        </div>

                                        <div class="form-group Editor-container">
                                            <label class="text-xs font-weight-bold text-uppercase text-muted">Konten
                                                Artikel (Markdown)</label>
                                            <textarea name="content"
                                                id="markdownEditor"><%= article ? article.content : '' %></textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="card mb-4 shadow-none border">
                                    <div class="card-header bg-white font-weight-bold small">PENGATURAN</div>
                                    <div class="card-body p-3">
                                        <div class="form-group mb-3">
                                            <label
                                                class="text-[10px] font-weight-bold text-muted uppercase">Kategori</label>
                                            <input type="text" name="category" class="form-control form-control-sm"
                                                value="<%= article ? article.category : '' %>"
                                                placeholder="Misal: TECH">
                                        </div>
                                        <div class="form-group mb-3">
                                            <label
                                                class="text-[10px] font-weight-bold text-muted uppercase">Tags</label>
                                            <input type="text" name="tags" class="form-control form-control-sm"
                                                value="<%= article && article.tags ? article.tags.join(', ') : '' %>"
                                                placeholder="nodejs, linux">
                                        </div>
                                    </div>
                                </div>

                                <div class="card mb-4 shadow-none border">
                                    <div class="card-header bg-white font-weight-bold small">COVER UTAMA</div>
                                    <div class="card-body p-3 text-center">
                                        <% if (article && article.coverImage) { %>
                                            <div class="mb-2 rounded overflow-hidden border">
                                                <img src="/uploads/<%= article.coverImage %>" class="w-100">
                                            </div>
                                            <% } %>
                                                <input type="file" name="coverImage" class="form-control-file small">
                                    </div>
                                </div>

                                <div class="card shadow-none border bg-light">
                                    <div class="card-body p-3">
                                        <h6 class="font-weight-bold small mb-2"><i class="fas fa-magic mr-1"></i> Editor
                                            Pro-Tips:</h6>
                                        <ul class="text-xs text-muted pl-3 mb-0">
                                            <li class="mb-1"><b>Paste (Ctrl+V)</b> gambar langsung ke dalam tulisan
                                                untuk upload instan.</li>
                                            <li class="mb-1">Klik ikon <b>Gambar</b> di toolbar untuk pilih file dari
                                                laptop.</li>
                                            <li>Gunakan <b>Preview</b> untuk melihat hasil akhir script & gambar.</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
            </form>
        </div>
    </div>

    <script>
        // Initialize Editor
        const easyMDE = new EasyMDE({
            element: document.getElementById('markdownEditor'),
            spellChecker: false,
            autosave: { enabled: false },
            placeholder: "Tulis artikel atau tempel kode script di sini...",
            minHeight: "550px",
            toolbar: [
                "bold", "italic", "heading", "|",
                "quote", "unordered-list", "ordered-list", "|",
                "link",
                {
                    name: "custom-image",
                    action: function (editor) {
                        document.getElementById('manualUpload').click();
                    },
                    className: "fa fa-image",
                    title: "Upload Image from Computer",
                },
                "|",
                "preview", "side-by-side", "fullscreen", "|",
                "guide"
            ]
        });

        // Helper for Manual Upload Change
        function manualUploadChange(input) {
            if (input.files[0]) {
                const file = input.files[0];
                const cursor = easyMDE.codemirror.getCursor();
                easyMDE.codemirror.replaceRange("![Mengunggah gambar...]()", cursor);
                const endPos = { line: cursor.line, ch: cursor.ch + 25 };

                performUpload(file, (url) => {
                    easyMDE.codemirror.replaceRange(`![Deskripsi Gambar](${url})`, cursor, endPos);
                }, (err) => {
                    easyMDE.codemirror.replaceRange(`[Gagal Upload: ${err}]`, cursor, endPos);
                });
                input.value = ''; // Reset input
            }
        }

        // Core Upload Logic
        async function performUpload(file, onSuccess, onError) {
            showIndicator(true);
            const formData = new FormData();
            formData.append('image', file);

            try {
                const res = await fetch('/admin/assets/upload', {
                    method: 'POST',
                    body: formData
                });

                if (!res.ok) {
                    const errorData = await res.json().catch(() => ({}));
                    throw new Error(errorData.error || `Server Error ${res.status}`);
                }

                const result = await res.json();
                if (result.data && result.data.link) {
                    // Return link but with dot prefix for static compatibility
                    const rawLink = result.data.link;
                    const fileName = rawLink.split('/').pop();
                    onSuccess('./uploads/' + fileName);
                    showIndicator(false);
                } else {
                    throw new Error("Format respon server tidak sesuai");
                }
            } catch (e) {
                console.error("Upload Catch Error:", e);
                showIndicator(false);
                onError(e.message);
            }
        }

        // Handle PASTE (Ctrl+V) Logic
        easyMDE.codemirror.on("paste", function (instance, event) {
            const items = (event.clipboardData || event.originalEvent.clipboardData).items;
            for (let i = 0; i < items.length; i++) {
                if (items[i].type.indexOf("image") !== -1) {
                    event.preventDefault();
                    const blob = items[i].getAsFile();

                    const cursor = instance.getCursor();
                    instance.replaceRange("![Mengunggah gambar...]()", cursor);
                    const endPos = { line: cursor.line, ch: cursor.ch + 25 };

                    performUpload(blob, (url) => {
                        instance.replaceRange(`![Deskripsi Gambar](${url})`, cursor, endPos);
                    }, (err) => {
                        instance.replaceRange(`[Gagal Upload: ${err}]`, cursor, endPos);
                    });
                }
            }
        });

        function showIndicator(show) {
            document.getElementById('uploadStatus').style.display = show ? 'block' : 'none';
        }
    </script>