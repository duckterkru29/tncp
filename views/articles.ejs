<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4 px-2">
            <div>
                <h1 class="h3 font-weight-bold mb-0">Blog Articles</h1>
                <p class="text-muted small mb-0">Bagikan pengetahuan Anda melalui postingan artikel IT yang berkualitas.
                </p>
            </div>
            <a href="/admin/articles/create" class="btn btn-primary shadow-sm">
                <i class="fas fa-pen-nib mr-2"></i> Tulis Artikel
            </a>
        </div>

        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th>Cover</th>
                                <th>Detail Artikel</th>
                                <th>Kategori</th>
                                <th>Statistik</th>
                                <th>Tanggal Publikasi</th>
                                <th class="text-right">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (articles.length===0) { %>
                                <tr>
                                    <td colspan="6" class="text-center py-5">
                                        <img src="https://cdni.iconscout.com/illustration/premium/thumb/writer-4481545-3720745.png"
                                            height="150" class="mb-3">
                                        <p class="text-muted">Editor artikel masih kosong. Mulailah menulis!</p>
                                    </td>
                                </tr>
                                <% } %>
                                    <% articles.forEach(row=> { %>
                                        <tr>
                                            <td style="width: 100px;">
                                                <div class="rounded-lg overflow-hidden border shadow-sm"
                                                    style="width: 80px; height: 50px; background: #f1f5f9;">
                                                    <img src="<%= row.coverImage ? '/uploads/' + row.coverImage : 'https://via.placeholder.com/80x50/6366f1/ffffff?text=Article' %>"
                                                        class="w-100 h-100 object-cover">
                                                </div>
                                            </td>
                                            <td>
                                                <div class="font-weight-bold text-dark">
                                                    <%= row.title %>
                                                </div>
                                                <div class="text-xs text-muted line-clamp-1" style="max-width: 300px;">
                                                    <%= row.excerpt %>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge badge-soft-info px-3 py-2 rounded-pill"
                                                    style="background: rgba(168, 85, 247, 0.1); color: var(--secondary);">
                                                    <%= row.category || 'TECH' %>
                                                </span>
                                            </td>
                                            <td>
                                                <div class="text-xs font-weight-bold">
                                                    <i class="far fa-eye mr-1 text-primary"></i>
                                                    <%= row.views || 0 %> Views<br>
                                                        <i class="far fa-clock mr-1 text-secondary"></i>
                                                        <%= row.readTime || 5 %> Min
                                                </div>
                                            </td>
                                            <td>
                                                <div class="text-sm font-weight-medium">
                                                    <%= new Date(row.publishedDate).toLocaleDateString('id-ID', {
                                                        day: '2-digit' , month: 'short' , year: 'numeric' }) %>
                                                </div>
                                            </td>
                                            <td class="text-right">
                                                <div class="btn-group">
                                                    <a href="/admin/articles/edit/<%= row.id %>"
                                                        class="btn btn-sm btn-outline-primary mr-2"
                                                        style="border-radius: 8px !important;">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <form action="/admin/articles/delete/<%= row.id %>" method="POST"
                                                        onsubmit="return confirm('Yakin ingin menghapus artikel ini?');">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                            style="border-radius: 8px !important;">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>