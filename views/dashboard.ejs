<style>
    .stat-card {
        border: none;
        border-radius: 24px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
        position: relative;
    }

    .stat-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    }

    .stat-card::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
        transform: rotate(30deg);
    }

    .card-primary {
        background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
    }

    .card-success {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    }

    .card-info {
        background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
    }

    .card-warning {
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    }

    .stat-icon-box {
        width: 64px;
        height: 64px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
    }

    .stat-label {
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.9) !important;
        margin-bottom: 4px;
    }

    .stat-value {
        font-size: 2.2rem;
        font-weight: 800;
        color: #ffffff !important;
        letter-spacing: -1px;
    }
</style>

<div class="row">
    <div class="col-lg-12">
        <div class="mb-5 d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h2 font-weight-black text-darker mb-1">Dashboard Analytics</h1>
                <p class="text-muted font-weight-medium">Pantau performa sistem dan interaksi pengunjung secara
                    real-time.</p>
            </div>
            <div class="d-none d-md-block">
                <span class="badge badge-soft-primary p-3 rounded-pill border shadow-sm">
                    <i class="fas fa-clock mr-2"></i> Update Terakhir: <%= new Date().toLocaleTimeString('id-ID') %>
                </span>
            </div>
        </div>

        <!-- Stats Overview Cards -->
        <div class="row mb-5">
            <div class="col-md-3 mb-4 mb-md-0">
                <div class="stat-card card-primary shadow-lg">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center">
                            <div class="stat-icon-box mr-4">
                                <i class="fas fa-users text-white fa-lg"></i>
                            </div>
                            <div>
                                <div class="stat-label">Total Visits</div>
                                <div class="stat-value">
                                    <%= stats.visits || 0 %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-4 mb-md-0">
                <div class="stat-card card-success shadow-lg">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center">
                            <div class="stat-icon-box mr-4">
                                <i class="fas fa-shopping-cart text-white fa-lg"></i>
                            </div>
                            <div>
                                <div class="stat-label">Order Clicks</div>
                                <div class="stat-value">
                                    <%= stats.orders || 0 %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-4 mb-md-0">
                <div class="stat-card card-info shadow-lg">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center">
                            <div class="stat-icon-box mr-4">
                                <i class="fas fa-book-open text-white fa-lg"></i>
                            </div>
                            <div>
                                <div class="stat-label">Reader Mode</div>
                                <div class="stat-value">
                                    <%= stats.articleViews || 0 %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card card-warning shadow-lg">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center">
                            <div class="stat-icon-box mr-4">
                                <i class="fas fa-archive text-white fa-lg"></i>
                            </div>
                            <div>
                                <div class="stat-label">Stock Inventory</div>
                                <div class="stat-value">
                                    <%= projectsCount + articlesCount %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Latest Activity Logs -->
            <div class="col-md-12">
                <div class="card shadow-sm border-0 rounded-lg">
                    <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
                        <h6 class="m-0 font-weight-bold text-dark">Aktivitas Terbaru Pengunjung</h6>
                        <span class="badge badge-light p-2 font-weight-normal border">Last 50 Events</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-items-center mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="text-xs font-weight-bold text-uppercase px-4">Aksi / Event</th>
                                        <th class="text-xs font-weight-bold text-uppercase">Detail</th>
                                        <th class="text-xs font-weight-bold text-uppercase">Waktu</th>
                                        <th class="text-xs font-weight-bold text-uppercase px-4">Alamat IP</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (stats.logs && stats.logs.length> 0) { %>
                                        <% stats.logs.forEach(log=> { %>
                                            <tr>
                                                <td class="px-4 py-3">
                                                    <% if (log.action==='visit' ) { %>
                                                        <span
                                                            class="badge badge-pill badge-light border px-3 py-1 text-primary">
                                                            <i class="fas fa-eye mr-1"></i> Page View
                                                        </span>
                                                        <% } else if (log.action==='order' ) { %>
                                                            <span class="badge badge-pill badge-success px-3 py-1">
                                                                <i class="fas fa-cash-register mr-1"></i> Order Click
                                                            </span>
                                                            <% } else { %>
                                                                <span class="badge badge-pill badge-info px-3 py-1">
                                                                    <i class="fas fa-book mr-1"></i> Read Article
                                                                </span>
                                                                <% } %>
                                                </td>
                                                <td><span class="text-sm font-weight-bold text-dark">
                                                        <%= log.details %>
                                                    </span></td>
                                                <td><span class="text-xs text-muted">
                                                        <%= new Date(log.time).toLocaleString('id-ID') %>
                                                    </span></td>
                                                <td class="px-4"><code
                                                        class="text-xs text-muted font-weight-bold border bg-light px-2 py-1 rounded"><%= log.ip %></code>
                                                </td>
                                            </tr>
                                            <% }) %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="4" class="text-center py-5 text-muted small">Belum
                                                            ada aktivitas tercatat.</td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>