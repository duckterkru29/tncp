<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>TNCP | Command Center</title>

    <!-- Google Font: Outfit -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <!-- Theme style AdminLTE -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css">

    <style>
        :root {
            --primary: #6366f1;
            --secondary: #a855f7;
            --dark-bg: #0f172a;
            --glass: rgba(255, 255, 255, 0.03);
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: #f8fafc;
        }

        /* Fix cut-off SELECT in Admin */
        select.form-control {
            height: auto !important;
            padding: 10px 15px !important;
            line-height: 1.5 !important;
        }

        /* Modern Sidebar */
        .main-sidebar {
            background: #0f172a !important;
            border-right: 1px solid rgba(255, 255, 255, 0.05) !important;
        }

        .brand-link {
            border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important;
            padding: 1.5rem 1rem !important;
        }

        .nav-pills .nav-link {
            border-radius: 12px !important;
            margin-bottom: 5px;
            padding: 12px 15px !important;
            font-weight: 500;
            color: #94a3b8 !important;
        }

        .nav-pills .nav-link.active {
            background: linear-gradient(135deg, var(--primary), var(--secondary)) !important;
            color: white !important;
            box-shadow: 0 10px 20px -5px rgba(99, 102, 241, 0.4);
        }

        .nav-pills .nav-link:hover:not(.active) {
            background: rgba(255, 255, 255, 0.05) !important;
            color: white !important;
        }

        /* Content Wrapper */
        .content-wrapper {
            background-color: #f8fafc !important;
            padding: 0 1rem;
        }

        /* Modern Navbar */
        .main-header {
            border-bottom: 1px solid #e2e8f0 !important;
            background: rgba(255, 255, 255, 0.8) !important;
            backdrop-filter: blur(10px);
        }

        /* Dashboard Cards & Layout */
        .card {
            border-radius: 20px !important;
            border: none !important;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03) !important;
            overflow: hidden;
            background: white !important;
        }

        .card-header {
            background: transparent !important;
            border-bottom: 1px solid #f1f5f9 !important;
            padding: 1.5rem !important;
        }

        .card-title {
            font-weight: 700 !important;
            font-size: 1.1rem !important;
            color: #1e293b;
        }

        /* Form Inputs */
        .form-control {
            border-radius: 12px !important;
            padding: 12px 15px !important;
            border: 1px solid #e2e8f0 !important;
            background: #f8fafc !important;
        }

        .form-control:focus {
            border-color: var(--primary) !important;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1) !important;
        }

        /* Buttons */
        .btn {
            border-radius: 12px !important;
            padding: 10px 20px !important;
            font-weight: 600 !important;
            transition: all 0.3s ease;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--secondary)) !important;
            border: none !important;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 15px rgba(99, 102, 241, 0.3) !important;
        }

        /* Table Stylings */
        .table thead th {
            border-top: none !important;
            text-transform: uppercase;
            font-size: 11px;
            letter-spacing: 1px;
            color: #64748b;
            padding: 1.2rem !important;
        }

        .table td {
            vertical-align: middle !important;
            padding: 1.2rem !important;
            color: #475569;
        }
    </style>
</head>

<body class="hold-transition sidebar-mini layout-fixed">
    <div class="wrapper">

        <!-- Navbar -->
        <nav class="main-header navbar navbar-expand navbar-white navbar-light sticky-top">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
                </li>
                <li class="nav-item d-none d-sm-inline-block">
                    <a href="/" class="nav-link font-weight-bold" target="_blank">
                        <i class="fas fa-external-link-alt mr-1 text-primary"></i> Live Preview
                    </a>
                </li>
            </ul>
            <ul class="navbar-nav ml-auto">
                <li class="nav-item">
                    <a href="/logout" class="nav-link text-danger font-weight-bold"
                        onclick="return confirm('Yakin ingin logout?')">
                        <i class="fas fa-power-off mr-1"></i> Sign Out
                    </a>
                </li>
            </ul>
        </nav>

        <!-- Sidebar -->
        <aside class="main-sidebar sidebar-dark-primary elevation-0">
            <a href="/admin" class="brand-link text-center py-4">
                <div class="d-flex align-items-center justify-content-center">
                    <img src="/logo.png" class="filter invert mr-2" style="height: 35px; width: auto;" alt="Logo">
                    <span class="brand-text font-weight-bold text-xl" style="letter-spacing: 2px;">TNCP <span
                            class="text-primary">CMS</span></span>
                </div>
            </a>

            <div class="sidebar px-3">
                <nav class="mt-4">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu">
                        <li class="nav-header text-uppercase text-xs font-weight-bold text-muted mb-2">Management</li>
                        <li class="nav-item">
                            <a href="/admin/dashboard"
                                class="nav-link <%= typeof title !== 'undefined' && title === 'Dashboard' ? 'active' : '' %>">
                                <i class="nav-icon fas fa-chart-line"></i>
                                <p>Dashboard</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/admin/projects"
                                class="nav-link <%= typeof title !== 'undefined' && title === 'Projects' ? 'active' : '' %>">
                                <i class="nav-icon fas fa-rocket"></i>
                                <p>Projects Portfolio</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/admin/articles"
                                class="nav-link <%= typeof title !== 'undefined' && title === 'Articles' ? 'active' : '' %>">
                                <i class="nav-icon fas fa-pen-nib"></i>
                                <p>Blog Articles</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="/admin/settings"
                                class="nav-link <%= typeof title !== 'undefined' && title === 'Settings' ? 'active' : '' %>">
                                <i class="nav-icon fas fa-cog"></i>
                                <p>Settings</p>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </aside>

        <!-- Content Area -->
        <div class="content-wrapper pt-4">
            <div class="container-fluid">
                <%- body %>
            </div>
        </div>

        <footer class="main-footer bg-transparent border-0 text-center text-muted text-sm pb-4">
            &copy; 2026 <b>TNCP Command Center</b>. Build for Performance.
        </footer>
    </div>

    <!-- Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.1/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>
</body>

</html>