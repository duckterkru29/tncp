<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Login | TNCP Command Center</title>

    <!-- Google Font: Outfit -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Outfit', 'sans-serif'],
                    },
                    colors: {
                        primary: '#6366f1',
                        secondary: '#a855f7',
                        dark: '#020617',
                    }
                }
            }
        }
    </script>

    <style>
        .bg-mesh {
            background-color: #020617;
            background-image:
                radial-gradient(at 0% 0%, rgba(99, 102, 241, 0.15) 0px, transparent 50%),
                radial-gradient(at 100% 0%, rgba(168, 85, 247, 0.15) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(244, 63, 94, 0.1) 0px, transparent 50%),
                radial-gradient(at 0% 100%, rgba(99, 102, 241, 0.1) 0px, transparent 50%);
        }

        .glass {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .gradient-text {
            background: linear-gradient(135deg, #818cf8 0%, #c084fc 50%, #fb7185 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        @keyframes float {

            0%,
            100% {
                transform: translateY(0) rotate(0deg);
            }

            50% {
                transform: translateY(-20px) rotate(5deg);
            }
        }

        .animate-float {
            animation: float 6s ease-in-out infinite;
        }
    </style>
</head>

<body class="bg-mesh min-h-screen flex items-center justify-center p-6">
    <div class="w-full max-w-[420px] relative">
        <!-- Floating Elements -->
        <div class="absolute -top-12 -left-12 w-24 h-24 bg-primary/20 rounded-full blur-2xl animate-pulse"></div>
        <div class="absolute -bottom-12 -right-12 w-32 h-32 bg-secondary/20 rounded-full blur-2xl animate-pulse"
            style="animation-delay: 1s;"></div>

        <div class="glass p-8 md:p-10 rounded-[40px] shadow-2xl relative overflow-hidden">
            <!-- Header -->
            <div class="text-center mb-10">
                <div
                    class="inline-flex w-20 h-20 bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl items-center justify-center shadow-xl mb-6 animate-float overflow-hidden">
                    <img src="/logo.png" class="w-12 h-12 object-contain filter invert opacity-90" alt="Logo">
                </div>
                <h1 class="text-3xl font-black tracking-tight text-white mb-2 uppercase italic">TNCP <span
                        class="gradient-text">ADMIN</span></h1>
                <p class="text-gray-400 text-sm font-medium">Lakukan autentikasi untuk masuk ke panel kontrol.</p>
            </div>

            <!-- Error Alert -->
            <% if (error) { %>
                <div
                    class="mb-6 p-4 rounded-2xl bg-red-500/10 border border-red-500/20 flex items-center gap-3 animate-bounce">
                    <i data-lucide="alert-circle" class="w-5 h-5 text-red-400"></i>
                    <p class="text-xs font-bold text-red-400">
                        <%= error %>
                    </p>
                </div>
                <% } %>

                    <!-- Form -->
                    <form action="/login" method="POST" class="space-y-5">
                        <div class="space-y-2">
                            <label
                                class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-500 ml-1">Username</label>
                            <div class="relative group">
                                <div
                                    class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-gray-500 group-focus-within:text-primary transition-colors">
                                    <i data-lucide="user" class="w-5 h-5"></i>
                                </div>
                                <input type="text" name="username" required autofocus
                                    class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 pl-12 pr-4 text-white placeholder:text-gray-600 focus:outline-none focus:border-primary focus:bg-white/[0.08] transition-all text-sm font-medium"
                                    placeholder="Ketik username admin...">
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label
                                class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-500 ml-1">Password</label>
                            <div class="relative group">
                                <div
                                    class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-gray-500 group-focus-within:text-primary transition-colors">
                                    <i data-lucide="lock" class="w-5 h-5"></i>
                                </div>
                                <input type="password" name="password" required
                                    class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 pl-12 pr-4 text-white placeholder:text-gray-600 focus:outline-none focus:border-primary focus:bg-white/[0.08] transition-all text-sm font-medium"
                                    placeholder="••••••••">
                            </div>
                        </div>

                        <button type="submit"
                            class="w-full bg-gradient-to-r from-primary to-secondary text-white py-5 rounded-2xl font-black text-lg shadow-xl shadow-primary/20 hover:shadow-primary/40 hover:-translate-y-1 active:scale-[0.98] transition-all uppercase tracking-widest mt-4">
                            Sign In <i data-lucide="chevron-right" class="inline w-5 h-5 ml-1"></i>
                        </button>
                    </form>

                    <!-- Footer -->
                    <footer class="mt-10 pt-8 border-t border-white/5 text-center">
                        <p class="text-gray-600 text-[10px] font-bold uppercase tracking-widest">&copy; 2026 TNCP
                            Portfolio v2.0</p>
                    </footer>
        </div>
    </div>

    <script>
        lucide.createIcons();
        document.addEventListener('contextmenu', event => event.preventDefault());
    </script>
</body>

</html>