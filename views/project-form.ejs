<% const title=project ? 'Edit Proyek' : 'Tambah Proyek Baru' ; %>

    <div class="row">
        <div class="col-lg-10 mx-auto">
            <div class="mb-4">
                <a href="/admin/projects" class="text-muted small font-weight-bold">
                    <i class="fas fa-arrow-left mr-1"></i> Kembali ke Daftar
                </a>
                <h1 class="h3 font-weight-bold mt-2">
                    <%= title %>
                </h1>
            </div>

            <form action="/admin/projects/save" method="POST" enctype="multipart/form-data">
                <% if(project) { %>
                    <input type="hidden" name="id" value="<%= project.id %>">
                    <input type="hidden" name="existingThumbnail" value="<%= project.thumbnail %>">
                    <% } %>

                        <div class="row">
                            <!-- Col Left: Main Info -->
                            <div class="col-md-8">
                                <div class="card mb-4">
                                    <div class="card-header"><span class="card-title">Informasi Dasar</span></div>
                                    <div class="card-body">
                                        <div class="form-group mb-4">
                                            <label class="text-xs font-weight-bold text-uppercase text-muted">Judul
                                                Proyek</label>
                                            <input type="text" name="title" class="form-control"
                                                value="<%= project ? project.title : '' %>" required
                                                placeholder="Contoh: Sistem POS Laundry">
                                        </div>
                                        <div class="form-group mb-4">
                                            <label class="text-xs font-weight-bold text-uppercase text-muted">Deskripsi
                                                Proyek</label>
                                            <textarea name="description" class="form-control" rows="5"
                                                placeholder="Jelaskan detail proyek Anda di sini..."><%= project ? project.description : '' %></textarea>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label
                                                        class="text-xs font-weight-bold text-uppercase text-muted">Tech
                                                        Stack (Pisahkan Koma)</label>
                                                    <input type="text" name="techStack" class="form-control"
                                                        value="<%= project && project.techStack ? project.techStack.join(', ') : '' %>"
                                                        placeholder="Laravel, Vue, AWS">
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label
                                                        class="text-xs font-weight-bold text-uppercase text-muted">Kategori</label>
                                                    <select name="category" class="form-control">
                                                        <option value="web" <%=project && project.category==='web'
                                                            ? 'selected' : '' %>>Web Application</option>
                                                        <option value="mobile" <%=project && project.category==='mobile'
                                                            ? 'selected' : '' %>>Mobile App</option>
                                                        <option value="system" <%=project && project.category==='system'
                                                            ? 'selected' : '' %>>Desktop/System</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="card mb-4">
                                    <div class="card-header"><span class="card-title">Fitur Unggulan</span></div>
                                    <div class="card-body">
                                        <div class="form-group">
                                            <label class="text-xs font-weight-bold text-uppercase text-muted">Daftar
                                                Fitur (1 fitur per baris)</label>
                                            <textarea name="features" class="form-control" rows="4"
                                                placeholder="Fitur 1&#10;Fitur 2..."><%= project && project.features ? project.features.join('\n') : '' %></textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Col Right: Pricing & Thumbnail -->
                            <div class="col-md-4">
                                <div class="card mb-4">
                                    <div class="card-header"><span class="card-title">Marketplace</span></div>
                                    <div class="card-body">
                                        <div class="form-group mb-4">
                                            <label class="text-xs font-weight-bold text-uppercase text-muted">Harga Jual
                                                (IDR)</label>
                                            <input type="number" name="price" class="form-control"
                                                value="<%= project ? project.price : '' %>" placeholder="0">
                                        </div>
                                        <div class="form-group mb-4">
                                            <label class="text-xs font-weight-bold text-uppercase text-muted">Harga
                                                Coret (IDR)</label>
                                            <input type="number" name="originalPrice" class="form-control"
                                                value="<%= project ? project.originalPrice : '' %>" placeholder="0">
                                        </div>

                                        <hr class="my-4">

                                        <div class="custom-control custom-switch mb-3">
                                            <input type="checkbox" name="isAvailable" class="custom-control-input"
                                                id="swAvailable" <%=!project || project.isAvailable ? 'checked' : '' %>>
                                            <label class="custom-control-label font-weight-bold"
                                                for="swAvailable">Tampilkan di Publik</label>
                                        </div>
                                        <div class="custom-control custom-switch">
                                            <input type="checkbox" name="isPopular" class="custom-control-input"
                                                id="swPopular" <%=project && project.isPopular ? 'checked' : '' %>>
                                            <label class="custom-control-label font-weight-bold" for="swPopular">Label
                                                Populer</label>
                                        </div>
                                    </div>
                                </div>

                                <div class="card mb-4">
                                    <div class="card-header"><span class="card-title">Media</span></div>
                                    <div class="card-body text-center">
                                        <% if (project && project.thumbnail) { %>
                                            <div class="mb-3 rounded-lg overflow-hidden border">
                                                <img src="/uploads/<%= project.thumbnail %>" class="w-100">
                                            </div>
                                            <% } %>
                                                <div class="form-group">
                                                    <label
                                                        class="text-xs font-weight-bold text-uppercase text-muted d-block text-left">Ganti
                                                        Screenshot</label>
                                                    <input type="file" name="thumbnail"
                                                        class="form-control-file border p-2 w-100 rounded-lg">
                                                </div>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-primary btn-block py-3 mt-4">
                                    <i class="fas fa-save mr-2"></i> Simpan Perubahan
                                </button>
                            </div>
                        </div>
            </form>
        </div>
    </div>