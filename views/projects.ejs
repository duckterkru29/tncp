<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4 px-2">
            <div>
                <h1 class="h3 font-weight-bold mb-0">Projects Portfolio</h1>
                <p class="text-muted small mb-0">Kelola semua showcase aplikasi dan source code Anda.</p>
            </div>
            <a href="/admin/projects/create" class="btn btn-primary shadow-sm">
                <i class="fas fa-plus-circle mr-2"></i> Tambah Proyek
            </a>
        </div>

        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th>Preview</th>
                                <th>Informasi Proyek</th>
                                <th>Kategori</th>
                                <th>Minat</th>
                                <th>Harga (IDR)</th>
                                <th>Status</th>
                                <th class="text-right">Aksi</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (projects.length===0) { %>
                                <tr>
                                    <td colspan="7" class="text-center py-5">
                                        <img src="https://cdni.iconscout.com/illustration/premium/thumb/empty-cart-2130356-1800917.png"
                                            height="150" class="mb-3">
                                        <p class="text-muted">Belum ada proyek yang terdaftar.</p>
                                    </td>
                                </tr>
                                <% } %>
                                    <% projects.forEach(project=> { %>
                                        <tr>
                                            <td style="width: 100px;">
                                                <div class="rounded-lg overflow-hidden border shadow-sm"
                                                    style="width: 80px; height: 50px; background: #f1f5f9;">
                                                    <img src="<%= project.thumbnail ? '/uploads/' + project.thumbnail : 'https://via.placeholder.com/80x50' %>"
                                                        class="w-100 h-100 object-cover">
                                                </div>
                                            </td>
                                            <td>
                                                <div class="font-weight-bold text-dark">
                                                    <%= project.title %>
                                                </div>
                                                <div class="text-xs text-muted">
                                                    <%= project.slug %>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge badge-soft-primary px-3 py-2 rounded-pill"
                                                    style="background: rgba(99, 102, 241, 0.1); color: var(--primary);">
                                                    <%= project.category.toUpperCase() %>
                                                </span>
                                            </td>
                                            <td>
                                                <div class="text-xs font-weight-bold text-info">
                                                    <i class="fas fa-shopping-basket mr-1"></i>
                                                    <%= project.interestCount || 0 %> Clicks
                                                </div>
                                            </td>
                                            <td class="font-weight-bold text-indigo">
                                                Rp <%= (project.price/1000).toFixed(0) %>K
                                            </td>
                                            <td>
                                                <% if (project.isAvailable) { %>
                                                    <span class="text-success small"><i
                                                            class="fas fa-check-circle mr-1"></i> Available</span>
                                                    <% } else { %>
                                                        <span class="text-danger small"><i
                                                                class="fas fa-times-circle mr-1"></i> Hidden</span>
                                                        <% } %>
                                            </td>
                                            <td class="text-right">
                                                <div class="btn-group">
                                                    <a href="/admin/projects/edit/<%= project.id %>"
                                                        class="btn btn-sm btn-outline-primary mr-2"
                                                        style="border-radius: 8px !important;">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <form action="/admin/projects/delete/<%= project.id %>"
                                                        method="POST"
                                                        onsubmit="return confirm('Yakin ingin menghapus ini?');">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                            style="border-radius: 8px !important;">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>