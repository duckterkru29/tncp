<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="mb-4">
            <h1 class="h3 font-weight-bold">Account Settings</h1>
            <p class="text-muted small">Kelola informasi akun admin dan konfigurasi publik website Anda.</p>
        </div>

        <% if (success) { %>
            <div class="alert alert-success alert-dismissible fade show rounded-xl border-0 shadow-sm mb-4"
                role="alert">
                <div class="d-flex align-items-center">
                    <i class="fas fa-check-circle mr-3 fa-lg"></i>
                    <div>
                        <strong class="d-block">Berhasil!</strong>
                        Pengaturan telah diperbarui dan akan segera diterapkan.
                    </div>
                </div>
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <% } %>

                <form action="/admin/settings/save" method="POST">
                    <div class="card mb-4">
                        <div class="card-header">
                            <span class="card-title"><i class="fas fa-user-shield mr-2 text-primary"></i> Identitas
                                Admin</span>
                        </div>
                        <div class="card-body">
                            <div class="form-group mb-4">
                                <label class="text-xs font-weight-bold text-uppercase text-muted">Nama Lengkap</label>
                                <input type="text" name="name" class="form-control" value="<%= settings.name %>"
                                    required>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group mb-4">
                                        <label class="text-xs font-weight-bold text-uppercase text-muted">Username
                                            Baru</label>
                                        <input type="text" name="username" class="form-control"
                                            value="<%= settings.username %>" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group mb-4">
                                        <label class="text-xs font-weight-bold text-uppercase text-muted">Password
                                            Baru</label>
                                        <input type="password" name="password" class="form-control"
                                            value="<%= settings.password %>" required>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card mb-4">
                        <div class="card-header">
                            <span class="card-title"><i class="fas fa-globe mr-2 text-secondary"></i> Konfigurasi
                                Publik</span>
                        </div>
                        <div class="card-body">
                            <div class="form-group mb-4">
                                <label class="text-xs font-weight-bold text-uppercase text-muted">Email Kontak</label>
                                <input type="email" name="email" class="form-control" value="<%= settings.email %>"
                                    required>
                            </div>
                            <div class="form-group mb-4">
                                <label class="text-xs font-weight-bold text-uppercase text-muted">Nomor WhatsApp
                                    (Format: 628xxx)</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-light border-right-0"><i
                                                class="fab fa-whatsapp text-success"></i></span>
                                    </div>
                                    <input type="text" name="whatsapp" class="form-control border-left-0"
                                        value="<%= settings.whatsapp %>" required>
                                </div>
                                <small class="text-muted">Nomor ini akan digunakan sebagai tujuan Checkout di
                                    Frontend.</small>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary px-5 py-3 shadow-sm btn-block">
                            <i class="fas fa-save mr-2"></i> Simpan Semua Perubahan
                        </button>
                    </div>
                </form>
    </div>
</div>